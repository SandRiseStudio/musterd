Output docs/assets/flagship.gif

# Width/Height are the GIF's pixel dimensions; FontSize sets how many
# terminal columns/rows fit. ~1000x780 holds the 80-col demo with padding.
Set FontSize 14
Set Width 1000
Set Height 780
Set Padding 20
Set Theme "Dracula"
Set PlaybackSpeed 1.5

Type "node examples/flagship-demo.mjs"
Enter
Sleep 12s
