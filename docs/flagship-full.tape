Output docs/assets/flagship-full.gif

# The full cut (~40s): adds single-active (refused duplicate) and the
# private handoff. Linked from docs/demo.md; the lean header GIF is
# flagship.tape. DEMO_FULL=1 selects the full script path.
Set FontSize 14
Set Width 1060
Set Height 980
Set Padding 20
Set Theme "Dracula"
Set PlaybackSpeed 1.0

Type "DEMO_FULL=1 node examples/flagship-demo.mjs"
Enter
Sleep 42s
