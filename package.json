{
  "name": "musterd-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,js,mjs,json,md}\"",
    "format:check": "prettier --check \"packages/**/*.ts\" \"tests/**/*.ts\" \"*.{ts,json}\"",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:scenarios": "vitest run tests/scenarios",
    "typecheck": "pnpm -r exec tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@musterd/mcp": "workspace:*",
    "@musterd/protocol": "workspace:*",
    "@musterd/server": "workspace:*",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^15.15.0",
    "prettier": "^3.8.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.1",
    "ulid": "^2.3.0",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
