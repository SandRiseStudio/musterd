{
  "name": "musterd-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r --if-present lint",
    "test": "vitest run",
    "test:scenarios": "vitest run tests/scenarios",
    "typecheck": "pnpm -r exec tsc --noEmit"
  },
  "devDependencies": {
    "@musterd/mcp": "workspace:*",
    "@musterd/protocol": "workspace:*",
    "@musterd/server": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "ulid": "^2.3.0",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
